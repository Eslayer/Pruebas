# Payment Gateway Configuration
WEBPAY_API_KEY=your_webpay_api_key
WEBPAY_API_SECRET=your_webpay_api_secret
WEBPAY_COMMERCE_CODE=your_commerce_code
WEBPAY_ENVIRONMENT=integration

MERCADOPAGO_ACCESS_TOKEN=your_mercadopago_access_token
MERCADOPAGO_PUBLIC_KEY=your_mercadopago_public_key
MERCADOPAGO_ENVIRONMENT=sandbox

# External Services Configuration
ORDER_SERVICE_URL=http://localhost:8081
KITCHEN_SERVICE_URL=http://localhost:8083

# JWT Configuration
JWT_SECRET=quickbite-secret-key-for-development-change-in-production
JWT_EXPIRATION=86400000

# Database Configuration (optional - defaults in application.properties)
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/quickbite_payment_db
# SPRING_DATASOURCE_USERNAME=root
# SPRING_DATASOURCE_PASSWORD=root
